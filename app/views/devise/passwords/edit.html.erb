<% content_for :title, "#{site_title} | Change Password" %>

<main class="max-w-screen-xl mx-auto px-4 sm:px-6 md:px-8 py-10 sm:py-12 md:py-16 grid grid-cols-1 lg:grid-cols-12 gap-10 md:gap-16 relative">
  <section class="lg:col-span-6 space-y-8 relative z-10">
    <span class="font-label text-xs uppercase tracking-widest text-primary">Password Recovery</span>
    <h1 class="font-headline text-4xl sm:text-5xl md:text-6xl italic text-on-surface">Seal a new password.</h1>
    <p class="text-body-md text-on-surface-variant leading-relaxed max-w-xl">
      Complete the reset token flow and replace the previous credential with a fresh one.
    </p>
  </section>

  <section class="lg:col-span-6 bg-surface-container-highest p-6 sm:p-8 md:p-10 shadow-sm relative overflow-hidden z-10">
    <div class="absolute top-0 left-0 w-1 h-full bg-primary opacity-20"></div>
    <h2 class="font-headline text-2xl italic mb-8 border-b border-outline-variant/30 pb-4">Change your password</h2>

    <%= form_for(resource, as: resource_name, url: password_path(resource_name), html: { method: :put, class: "grid gap-8" }) do |f| %>
      <%= render "devise/shared/error_messages", resource: resource %>
      <%= f.hidden_field :reset_password_token %>

      <div class="flex flex-col gap-2">
        <div class="flex items-center justify-between gap-4">
          <%= f.label :password, "New password", class: "font-label text-xs uppercase tracking-widest text-on-surface-variant" %>
          <% if @minimum_password_length %>
            <span class="text-xs text-on-surface-variant italic"><%= @minimum_password_length %> characters minimum</span>
          <% end %>
        </div>
        <%= f.password_field :password, autofocus: true, autocomplete: "new-password", class: "bg-transparent border-t-0 border-x-0 border-b border-outline/40 focus:ring-0 focus:border-primary text-on-surface font-headline italic text-lg transition-all py-2" %>
      </div>

      <div class="flex flex-col gap-2">
        <%= f.label :password_confirmation, "Confirm new password", class: "font-label text-xs uppercase tracking-widest text-on-surface-variant" %>
        <%= f.password_field :password_confirmation, autocomplete: "new-password", class: "bg-transparent border-t-0 border-x-0 border-b border-outline/40 focus:ring-0 focus:border-primary text-on-surface font-headline italic text-lg transition-all py-2" %>
      </div>

      <%= f.submit "Change my password", class: "w-full bg-primary text-on-primary py-4 rounded-sm font-label uppercase tracking-widest text-sm hover:bg-surface-tint transition-all cursor-pointer" %>
    <% end %>

    <%= render "devise/shared/links" %>
  </section>
</main>
