<% content_for :title, "#{site_title} | Archive Access" %>

<main class="max-w-screen-xl mx-auto px-4 sm:px-6 md:px-8 py-10 sm:py-12 md:py-16 grid grid-cols-1 lg:grid-cols-12 gap-10 md:gap-16 relative">
  <section class="lg:col-span-6 space-y-8 relative z-10">
    <span class="font-label text-xs uppercase tracking-widest text-primary">Archive Access</span>
    <h1 class="font-headline text-4xl sm:text-5xl md:text-6xl italic text-on-surface">Return to the private ledger.</h1>
    <p class="text-body-md text-on-surface-variant leading-relaxed max-w-xl">
      Sign in to review saved account details, recover access to your correspondence record, and finalize the Shipping Ledger when a basket is ready.
    </p>
  </section>

  <section class="lg:col-span-6 bg-surface-container-highest p-6 sm:p-8 md:p-10 shadow-sm relative overflow-hidden z-10">
    <div class="absolute top-0 left-0 w-1 h-full bg-primary opacity-20"></div>
    <h2 class="font-headline text-2xl italic mb-8 border-b border-outline-variant/30 pb-4">Sign In</h2>

    <%= form_for(resource, as: resource_name, url: session_path(resource_name), html: { class: "grid gap-8" }) do |f| %>
      <%= render "devise/shared/error_messages", resource: resource %>

      <div class="flex flex-col gap-2">
        <%= f.label :email, class: "font-label text-xs uppercase tracking-widest text-on-surface-variant" %>
        <%= f.email_field :email, autofocus: true, autocomplete: "email", class: "bg-transparent border-t-0 border-x-0 border-b border-outline/40 focus:ring-0 focus:border-primary text-on-surface font-headline italic text-lg transition-all py-2" %>
      </div>

      <div class="flex flex-col gap-2">
        <%= f.label :password, class: "font-label text-xs uppercase tracking-widest text-on-surface-variant" %>
        <%= f.password_field :password, autocomplete: "current-password", class: "bg-transparent border-t-0 border-x-0 border-b border-outline/40 focus:ring-0 focus:border-primary text-on-surface font-headline italic text-lg transition-all py-2" %>
      </div>

      <% if devise_mapping.rememberable? %>
        <label class="flex items-center gap-3 cursor-pointer">
          <%= f.check_box :remember_me, class: "w-4 h-4 rounded-sm border-outline/40 text-primary focus:ring-primary/20" %>
          <span class="font-body text-sm text-on-surface-variant">Keep this archive access remembered</span>
        </label>
      <% end %>

      <%= f.submit "Log in", class: "w-full bg-primary text-on-primary py-4 rounded-sm font-label uppercase tracking-widest text-sm hover:bg-surface-tint transition-all cursor-pointer" %>
    <% end %>

    <%= render "devise/shared/links" %>
  </section>
</main>
