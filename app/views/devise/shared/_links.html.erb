<div class="mt-8 flex flex-wrap gap-4 font-label text-xs uppercase tracking-widest text-on-surface-variant">
  <% if controller_name != "sessions" %>
    <%= link_to "Log in", new_session_path(resource_name), class: "hover:text-primary transition-colors" %>
  <% end %>

  <% if devise_mapping.registerable? && controller_name != "registrations" %>
    <%= link_to "Sign up", new_registration_path(resource_name), class: "hover:text-primary transition-colors" %>
  <% end %>

  <% if devise_mapping.recoverable? && controller_name != "passwords" && controller_name != "registrations" %>
    <%= link_to "Forgot your password?", new_password_path(resource_name), class: "hover:text-primary transition-colors" %>
  <% end %>
</div>
