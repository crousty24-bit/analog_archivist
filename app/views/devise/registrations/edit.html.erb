<% content_for :title, "#{site_title} | Edit Archive Access" %>

<main class="max-w-screen-xl mx-auto px-4 sm:px-6 md:px-8 py-10 sm:py-12 md:py-16 grid grid-cols-1 lg:grid-cols-12 gap-10 md:gap-16 relative">
  <section class="lg:col-span-6 space-y-8 relative z-10">
    <span class="font-label text-xs uppercase tracking-widest text-primary">Account Ledger</span>
    <h1 class="font-headline text-4xl sm:text-5xl md:text-6xl italic text-on-surface">Update archive access.</h1>
    <p class="text-body-md text-on-surface-variant leading-relaxed max-w-xl">
      Keep the correspondence record current and confirm password changes intentionally. Account cancellation remains available below because Devise exposes it by default.
    </p>
  </section>

  <section class="lg:col-span-6 space-y-10 relative z-10">
    <div class="bg-surface-container-highest p-6 sm:p-8 md:p-10 shadow-sm relative overflow-hidden">
      <div class="absolute top-0 left-0 w-1 h-full bg-primary opacity-20"></div>
      <h2 class="font-headline text-2xl italic mb-8 border-b border-outline-variant/30 pb-4">Edit Access</h2>

      <%= form_for(resource, as: resource_name, url: registration_path(resource_name), html: { method: :put, class: "grid gap-8" }) do |f| %>
        <%= render "devise/shared/error_messages", resource: resource %>

        <div class="flex flex-col gap-2">
          <%= f.label :email, class: "font-label text-xs uppercase tracking-widest text-on-surface-variant" %>
          <%= f.email_field :email, autofocus: true, autocomplete: "email", class: "bg-transparent border-t-0 border-x-0 border-b border-outline/40 focus:ring-0 focus:border-primary text-on-surface font-headline italic text-lg transition-all py-2" %>
        </div>

        <% if devise_mapping.confirmable? && resource.pending_reconfirmation? %>
          <p class="text-sm text-on-surface-variant italic">Currently waiting confirmation for: <%= resource.unconfirmed_email %></p>
        <% end %>

        <div class="flex flex-col gap-2">
          <div class="flex items-center justify-between gap-4">
            <%= f.label :password, class: "font-label text-xs uppercase tracking-widest text-on-surface-variant" %>
            <span class="text-xs text-on-surface-variant italic">Leave blank to keep the current one</span>
          </div>
          <%= f.password_field :password, autocomplete: "new-password", class: "bg-transparent border-t-0 border-x-0 border-b border-outline/40 focus:ring-0 focus:border-primary text-on-surface font-headline italic text-lg transition-all py-2" %>
        </div>

        <div class="flex flex-col gap-2">
          <%= f.label :password_confirmation, class: "font-label text-xs uppercase tracking-widest text-on-surface-variant" %>
          <%= f.password_field :password_confirmation, autocomplete: "new-password", class: "bg-transparent border-t-0 border-x-0 border-b border-outline/40 focus:ring-0 focus:border-primary text-on-surface font-headline italic text-lg transition-all py-2" %>
        </div>

        <div class="flex flex-col gap-2">
          <%= f.label :current_password, class: "font-label text-xs uppercase tracking-widest text-on-surface-variant" %>
          <%= f.password_field :current_password, autocomplete: "current-password", class: "bg-transparent border-t-0 border-x-0 border-b border-outline/40 focus:ring-0 focus:border-primary text-on-surface font-headline italic text-lg transition-all py-2" %>
        </div>

        <%= f.submit "Update", class: "w-full bg-primary text-on-primary py-4 rounded-sm font-label uppercase tracking-widest text-sm hover:bg-surface-tint transition-all cursor-pointer" %>
      <% end %>
    </div>

    <div class="bg-surface-container-low p-6 sm:p-8 shadow-sm">
      <h3 class="font-headline text-2xl italic mb-4">Cancel my account</h3>
      <p class="text-sm text-on-surface-variant mb-6">This permanently removes the current Devise user record from the archive.</p>
      <%= button_to "Cancel my account", registration_path(resource_name), data: { turbo_confirm: "Are you sure?" }, method: :delete, class: "bg-on-background text-surface px-6 py-3 font-label uppercase tracking-widest text-xs cursor-pointer" %>
    </div>
  </section>
</main>
