<% content_for :title, "#{site_title} | Home" %>

<main>
  <section class="relative flex items-center px-4 sm:px-6 md:px-8 py-16 md:py-20 overflow-hidden md:min-h-[870px]">
    <div class="max-w-screen-2xl mx-auto w-full grid grid-cols-1 md:grid-cols-12 gap-10 md:gap-12 items-center">
      <div class="md:col-span-5 z-10">
        <span class="font-label text-tertiary uppercase tracking-[0.3em] text-xs mb-4 block">Established 1924</span>
        <h1 class="font-headline text-on-background text-5xl sm:text-6xl lg:text-8xl italic leading-[1.05] mb-8">
          The Fine Art of
          <span class="text-primary underline decoration-outline-variant underline-offset-8">Collecting</span>
        </h1>
        <p class="text-body-md text-on-surface-variant max-w-md mb-10 leading-relaxed font-light">
          Curating the eclectic, the mechanical, and the feline. A sanctuary for rare pinball machines, artisan oil lamps, and high-altitude cat habitats.
        </p>
        <div class="flex flex-wrap gap-4">
          <%= link_to "Enter the Archive", catalog_index_path, class: "w-full sm:w-auto bg-primary text-on-primary px-8 py-4 text-center text-sm font-label uppercase tracking-widest rounded-none hover:bg-surface-tint transition-colors" %>
          <%= link_to "Latest Finds", "#recent-acquisitions", class: "w-full sm:w-auto bg-secondary-container text-on-secondary-container px-8 py-4 text-center text-sm font-label uppercase tracking-widest rounded-none border border-outline/10 hover:bg-secondary-fixed transition-colors" %>
        </div>
      </div>

      <div class="md:col-span-7 relative">
        <div class="aspect-[4/5] md:aspect-square overflow-hidden rounded-lg shadow-2xl rotate-2 hover:rotate-0 transition-transform duration-700">
          <%= image_tag "https://lh3.googleusercontent.com/aida-public/AB6AXuA9aFqIwo7BKMPLK_cLd4--W5Nhs9TqH7T5hC6dgUmFhZkq35xOtmLE9_5DoS5E23q2rNkIHvrgjPg3T26n3HdwrqIZ1aXT839lYBM0YN954vCrwITn1HEoN_KYnf25xL42yHG2ey2T6YeryraRG9ynLtggJljLPS9BD9Z0vp2eBMOmsAzY5UsUAdIqbUcsi5s4kFjRRENd3-QUOj_jndDGxWtLHXeaG5sjhdeC4M-SDwZYD85YHC_j9pnogYSzr5VErSz5F2B4sdEH", alt: "Vintage studio with eclectic items", class: "w-full h-full object-cover grayscale-[20%] sepia-[15%]" %>
        </div>

        <div class="absolute -bottom-12 -left-12 w-64 h-80 hidden lg:block overflow-hidden rounded-lg shadow-xl -rotate-6 border-8 border-surface-container-lowest">
          <%= image_tag "https://lh3.googleusercontent.com/aida-public/AB6AXuCkYenEc_w5DPS_QAfDppjfPge9TUeXTwji4Ne0eJi8fNVxzr_Dur-C_s1RsUVEPN9Dtdtba3oL-iecLcZngkmO4b9jDrUpBUHJuppOYKjBBMGU3HeScdEx6tR-H4Ouu6s0YK8983i03TzjTTopebmR5DmFmUTNgq1JWXOu7oadKC8WNDm63JEBK-RCOm0kIbYAqsyI3E2kCqsM_qIv4DMFNitnSq04CBQuUrPxzGzcdPnjq1i7I2iPvwZ8LPT2hoZAnlWBjv3JyE8z", alt: "Close up of mechanical parts", class: "w-full h-full object-cover" %>
        </div>
      </div>
    </div>
  </section>

  <section class="py-20 md:py-24 px-4 sm:px-6 md:px-8 bg-surface-container-low">
    <div class="max-w-screen-2xl mx-auto">
      <div class="mb-16 text-center">
        <h2 class="font-headline text-3xl sm:text-4xl italic mb-4">Explore the Vaults</h2>
        <div class="h-px w-24 bg-primary mx-auto"></div>
      </div>

      <div class="grid grid-cols-1 md:grid-cols-4 grid-rows-2 gap-6 h-auto md:h-[800px]">
        <% @home_categories.each do |category| %>
          <% tile = home_category_tile_copy(category) %>
          <%= link_to catalog_index_path(category: category.slug), class: "#{tile[:layout_class]} relative group overflow-hidden rounded-xl bg-surface-container-highest min-h-[220px]" do %>
            <%= image_tag category.image_remote_url, alt: category.image_alt_text.presence || category.name, class: "w-full h-full object-cover transition-transform duration-700 group-hover:scale-105" %>
            <div class="theme-hero-overlay absolute inset-0 opacity-60"></div>
            <div class="absolute bottom-0 left-0 p-6 md:p-8">
              <h3 class="font-headline <%= tile[:title_class] %> text-surface-container-lowest italic mb-2"><%= category.name %></h3>
              <% if tile[:teaser].present? %>
                <p class="text-surface-container-lowest/80 text-sm font-label tracking-widest uppercase"><%= tile[:teaser] %></p>
              <% end %>
            </div>
          <% end %>
        <% end %>
      </div>
    </div>
  </section>

  <section class="py-20 md:py-24 px-4 sm:px-6 md:px-8 max-w-screen-2xl mx-auto">
    <div class="flex flex-col lg:flex-row gap-12 md:gap-16 items-start">
      <div class="lg:w-1/2 relative">
        <div class="bg-surface-container-highest p-4 rounded-xl">
          <%= image_tag @featured_product.hero_image.remote_url, alt: @featured_product.hero_image.alt_text.presence || @featured_product.title, class: "w-full rounded-lg" %>
        </div>
        <div class="mt-6 flex flex-wrap gap-4">
          <% @featured_product.gallery_images.first(2).each_with_index do |image, index| %>
            <div class="w-24 h-24 rounded bg-surface-dim overflow-hidden">
              <%= image_tag image.remote_url, alt: image.alt_text.presence || "#{@featured_product.title} detail #{index + 1}", class: "w-full h-full object-cover opacity-60 hover:opacity-100 transition-opacity cursor-pointer" %>
            </div>
          <% end %>
        </div>
      </div>

      <div class="lg:w-1/2">
        <span class="font-label text-primary text-xs tracking-widest uppercase mb-4 block italic">Curator's Choice</span>
        <h2 class="font-headline text-4xl sm:text-5xl italic mb-6"><%= @featured_product.title %></h2>
        <p class="text-body-md text-on-surface-variant mb-12 max-w-xl leading-loose">
          <%= @featured_product.detail_body_for_display %>
        </p>

        <div class="bg-surface-container-highest p-6 sm:p-8 md:p-10 rounded-xl relative overflow-hidden">
          <div class="absolute top-0 right-0 p-4 opacity-10">
            <span class="material-symbols-outlined text-9xl">settings</span>
          </div>

          <div class="relative z-10">
            <div class="flex flex-col gap-2 sm:flex-row sm:justify-between sm:items-end mb-8 border-b border-outline/10 pb-6">
              <span class="font-label uppercase tracking-widest text-xs opacity-60">Acquisition Price</span>
              <span class="font-headline text-4xl italic text-primary"><%= archive_price(@featured_product.price_cents, strip_zero_cents: false) %></span>
            </div>

            <ul class="space-y-6 font-label text-xs tracking-widest uppercase text-on-surface">
              <% @featured_product.product_specifications.first(3).each do |spec| %>
                <li class="flex flex-col items-start gap-1 sm:flex-row sm:justify-between sm:gap-6">
                  <span class="opacity-50"><%= spec.label %></span>
                  <span class="text-left sm:text-right"><%= spec.value %></span>
                </li>
              <% end %>
              <li class="flex flex-col items-start gap-1 sm:flex-row sm:justify-between sm:gap-6">
                <span class="opacity-50">Availability</span>
                <span class="text-left sm:text-right text-tertiary"><%= @featured_product.availability %></span>
              </li>
            </ul>

            <div class="mt-12 flex flex-col sm:flex-row gap-4">
              <%= form_with url: cart_items_path, method: :post, class: "flex-1" do |form| %>
                <%= form.hidden_field :product_id, value: @featured_product.id %>
                <%= form.hidden_field :quantity, value: 1 %>
                <%= form.submit "Add to Private Ledger", class: "w-full bg-primary text-on-primary py-5 rounded-none font-label uppercase tracking-[0.2em] text-xs hover:bg-on-background transition-all active:scale-95 cursor-pointer" %>
              <% end %>

              <%= link_to "View Full Spec Sheet", catalog_path(@featured_product), class: "flex-1 bg-secondary-container text-on-secondary-container py-5 text-center font-label uppercase tracking-[0.2em] text-xs border border-outline/10 hover:bg-secondary-fixed transition-colors" %>
            </div>
          </div>
        </div>
      </div>
    </div>
  </section>

  <section class="py-20 md:py-24 px-4 sm:px-6 md:px-8 bg-surface-container" id="recent-acquisitions">
    <div class="max-w-screen-2xl mx-auto">
      <div class="flex justify-between items-baseline mb-16 flex-wrap gap-4">
        <h2 class="font-headline text-3xl sm:text-4xl italic">Recent Acquisitions</h2>
        <%= link_to "View All Curiosities", catalog_index_path, class: "font-label text-xs uppercase tracking-widest border-b border-on-surface pb-1 hover:text-primary transition-colors" %>
      </div>

      <div class="grid grid-cols-1 md:grid-cols-2 lg:grid-cols-4 gap-8">
        <% @recent_products.each do |product| %>
          <%= render "shared/product_card", product: product, variant: :recent %>
        <% end %>
      </div>
    </div>
  </section>

  <%= render "shared/newsletter", variant: :home %>
</main>
