<% content_for :title, "#{site_title} | Catalogue" %>
<% content_for :body_class, "bg-background text-on-surface font-body selection:bg-primary-container selection:text-on-primary-container overflow-x-hidden" %>

<main class="relative min-h-screen">
  <section class="max-w-screen-2xl mx-auto px-4 sm:px-6 md:px-8 pt-16 md:pt-20 pb-12">
    <div class="flex flex-col md:flex-row md:items-end justify-between gap-8 border-b border-outline-variant/20 pb-12">
      <div class="max-w-2xl">
        <h1 class="font-headline text-5xl sm:text-6xl md:text-8xl text-on-surface mb-6 leading-tight">
          The Collected <span class="italic text-primary">Curiosities</span>
        </h1>
        <p class="font-body text-lg text-on-surface-variant max-w-md leading-relaxed">
          A meticulously sourced inventory of the tactile, the mechanical, and the nostalgic. Every piece holds a history; every acquisition tells a story.
        </p>
      </div>

      <%= form_with url: catalog_index_path, method: :get, class: "w-full md:w-auto bg-surface-container-high p-5 sm:p-6 rounded-lg flex flex-col gap-4 min-w-0 md:min-w-[300px]" do |form| %>
        <span class="font-label text-xs uppercase tracking-widest text-on-surface-variant">Archivist Sorting Ledger</span>
        <div class="flex flex-col gap-2">
          <div class="flex flex-col items-start gap-1 border-b border-outline/20 pb-2 sm:flex-row sm:justify-between sm:items-center">
            <span class="font-body text-sm italic">Sort by:</span>
            <%= form.select :sort,
                            options_for_select([["Featured", "featured"], ["Price ↑", "price-asc"], ["Price ↓", "price-desc"], ["Title A-Z", "title"]], @sort),
                            {},
                            class: "w-full sm:w-auto bg-transparent border-none focus:ring-0 font-label text-sm text-primary cursor-pointer p-0 text-left sm:text-right appearance-none",
                            onchange: "this.form.requestSubmit()" %>
          </div>
          <div class="flex flex-col items-start gap-1 border-b border-outline/20 pb-2 sm:flex-row sm:justify-between sm:items-center">
            <span class="font-body text-sm italic">Category:</span>
            <%= form.select :category,
                            options_for_select([["All Curiosities", nil]] + navigation_categories.map { |category| [category.name, category.slug] }, @selected_category&.slug),
                            {},
                            class: "w-full sm:w-auto bg-transparent border-none focus:ring-0 font-label text-sm text-primary cursor-pointer p-0 text-left sm:text-right appearance-none",
                            onchange: "this.form.requestSubmit()" %>
          </div>
          <div class="flex flex-col items-start gap-2 pt-2 sm:flex-row sm:justify-between sm:items-center">
            <span class="font-body text-sm italic">Display:</span>
            <div class="flex w-full justify-end gap-4 sm:w-auto">
              <button class="text-primary" type="button"><span class="material-symbols-outlined text-sm">grid_view</span></button>
              <button class="text-on-surface-variant/50" type="button"><span class="material-symbols-outlined text-sm">view_list</span></button>
            </div>
          </div>
        </div>
      <% end %>
    </div>
  </section>

  <section class="max-w-screen-2xl mx-auto px-4 sm:px-6 md:px-8 pb-24 md:pb-32">
    <% if @products.any? %>
      <div class="grid grid-cols-1 md:grid-cols-2 lg:grid-cols-4 items-start gap-y-14 md:gap-y-20 gap-x-8 lg:gap-x-12">
        <% @products.each do |product| %>
          <%= render "shared/product_card", product: product, variant: :catalog %>
        <% end %>
      </div>
    <% else %>
      <div class="rounded-lg border border-outline-variant/20 bg-surface-container-low p-6 sm:p-10">
        <h2 class="font-headline text-3xl italic mb-4">No curiosities in this shelf.</h2>
        <p class="text-on-surface-variant mb-6">
          This filter currently resolves to an empty ledger. Return to the full archive or choose another category.
        </p>
        <%= link_to "Return to Catalogue", catalog_index_path, class: "inline-flex bg-primary text-on-primary px-6 py-3 font-label text-xs uppercase tracking-widest rounded-sm" %>
      </div>
    <% end %>
  </section>

  <%= render "shared/newsletter", variant: :catalog %>
</main>
