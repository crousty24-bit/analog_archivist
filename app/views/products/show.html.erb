<% content_for :title, "#{site_title} | #{@product.title}" %>

<main class="max-w-screen-2xl mx-auto px-4 sm:px-6 md:px-12 py-10 md:py-12 lg:py-20">
  <nav class="mb-8 md:mb-12 flex flex-wrap items-center gap-2 text-[10px] sm:text-label-md text-on-surface-variant font-medium tracking-widest uppercase">
    <%= link_to "Archive", catalog_index_path, class: "hover:text-primary" %>
    <span class="material-symbols-outlined text-[12px]">chevron_right</span>
    <%= link_to @product.category.hero_label, catalog_index_path(category: @product.category.slug), class: "hover:text-primary" %>
    <span class="material-symbols-outlined text-[12px]">chevron_right</span>
    <span class="text-on-surface"><%= @product.title %></span>
  </nav>

  <div class="grid grid-cols-1 lg:grid-cols-12 gap-10 md:gap-16 items-start">
    <div class="lg:col-span-7 space-y-6 md:space-y-8">
      <div class="relative group">
        <div class="absolute -top-4 -left-4 w-24 h-24 bg-tertiary/10 rounded-full blur-2xl group-hover:bg-tertiary/20 transition-all"></div>
        <%= image_tag @product.hero_image.remote_url, alt: @product.hero_image.alt_text.presence || @product.title, class: "w-full aspect-[4/5] object-cover rounded-lg shadow-xl relative z-10 border-[0.25rem] border-surface-container-lowest" %>
      </div>

      <div class="grid grid-cols-2 gap-4 sm:gap-6">
        <% @product.gallery_images.first(2).each_with_index do |image, index| %>
          <%= image_tag image.remote_url, alt: image.alt_text.presence || "#{@product.title} detail #{index + 1}", class: "w-full aspect-square object-cover rounded-lg shadow-md grayscale-[0.2] hover:grayscale-0 transition-all duration-500" %>
        <% end %>
      </div>
    </div>

    <div class="lg:col-span-5 sticky top-32 space-y-8 md:space-y-10">
      <div class="space-y-4">
        <% title_primary, title_emphasis = product_heading_segments(@product) %>
        <h1 class="text-4xl sm:text-5xl md:text-6xl font-headline font-bold text-on-surface tracking-tight leading-[0.95]">
          <%= title_primary %>
          <% if title_emphasis.present? %>
            <br>
            <span class="italic font-normal text-tertiary"><%= title_emphasis %></span>
          <% end %>
        </h1>
        <div class="flex items-center gap-4 py-2 flex-wrap">
          <span class="bg-tertiary text-on-tertiary px-3 py-1 text-[10px] uppercase tracking-widest font-bold rounded-sm"><%= @product.badge.presence || "Collector Grade" %></span>
          <% if @product.availability.present? %>
            <span class="text-on-surface-variant font-label text-sm italic"><%= @product.availability %></span>
          <% end %>
        </div>
      </div>

      <div class="space-y-6">
        <% if @product.detail_quote_for_display.present? %>
          <p class="text-lg sm:text-xl font-headline italic leading-relaxed text-on-surface/80">
            <%= @product.detail_quote_for_display %>
          </p>
        <% end %>
        <% if @product.detail_body_for_display.present? %>
          <p class="text-body-md leading-loose text-on-surface-variant">
            <%= @product.detail_body_for_display %>
          </p>
        <% end %>
      </div>

      <% identity_rows = product_identity_rows(@product) %>
      <% if identity_rows.any? %>
        <div class="grid grid-cols-1 md:grid-cols-3 gap-3">
          <% identity_rows.each do |label, value| %>
            <div class="theme-glass-panel p-4 rounded-[0.85rem] border border-outline/20">
              <span class="block mb-2 text-[10px] uppercase tracking-[0.18em] text-outline"><%= label %></span>
              <span class="font-headline text-lg"><%= value %></span>
            </div>
          <% end %>
        </div>
      <% end %>

      <section class="bg-surface-container-highest p-6 sm:p-8 rounded-lg space-y-6 shadow-inner relative overflow-hidden">
        <div class="absolute top-0 right-0 p-4 opacity-10">
          <span class="material-symbols-outlined text-6xl">settings_input_component</span>
        </div>
        <h3 class="font-label text-xs uppercase tracking-[0.2em] font-bold text-outline">Technical Ledger</h3>
        <div class="space-y-4 font-body text-sm">
          <% product_spec_rows(@product).each do |label, value| %>
            <div class="flex flex-col items-start gap-1 sm:flex-row sm:justify-between sm:gap-6 border-b border-outline-variant/20 pb-2 last:border-b-0 last:pb-0">
              <span class="text-on-surface-variant"><%= label %></span>
              <span class="font-medium text-left sm:text-right"><%= value %></span>
            </div>
          <% end %>
        </div>
      </section>

      <div class="pt-8 space-y-8">
        <div class="flex flex-col">
          <span class="text-label-md text-on-surface-variant uppercase tracking-widest">Current Valuation</span>
          <span class="text-3xl sm:text-4xl font-headline font-bold text-primary tracking-tighter"><%= archive_price(@product.price_cents, strip_zero_cents: false) %></span>
        </div>

        <div class="flex flex-col sm:flex-row gap-4">
          <%= form_with url: cart_items_path, method: :post, class: "flex-1" do |form| %>
            <%= form.hidden_field :product_id, value: @product.id %>
            <%= form.hidden_field :quantity, value: 1 %>
            <%= form.button type: :submit, class: "w-full bg-primary text-on-primary py-5 px-8 flex items-center justify-center gap-3 rounded-sm shadow-lg hover:bg-surface-tint active:scale-[0.98] transition-all group cursor-pointer" do %>
              <span class="material-symbols-outlined group-hover:rotate-12 transition-transform">shopping_basket</span>
              <span class="font-label font-bold uppercase tracking-widest text-sm">Add to Basket</span>
            <% end %>
          <% end %>

          <%= link_to shipping_ledger_path, class: "bg-surface-container-high text-on-surface-variant py-5 px-6 rounded-sm hover:bg-surface-dim transition-colors flex items-center justify-center" do %>
            <span class="material-symbols-outlined">bookmark</span>
          <% end %>
        </div>

        <div class="flex items-center gap-2 text-xs text-on-surface-variant/70 italic justify-center lg:justify-start">
          <span class="material-symbols-outlined text-sm">local_shipping</span>
          White-glove archive delivery included globally.
        </div>
      </div>
    </div>
  </div>

  <% if @product.story_title_for_display.present? && @product.story_body_for_display.present? %>
    <section class="mt-20 md:mt-32 grid grid-cols-1 md:grid-cols-2 gap-10 md:gap-12 items-center border-t border-outline-variant/10 pt-14 md:pt-20">
      <div class="order-2 md:order-1">
        <%= image_tag @product.story_image.remote_url, alt: @product.story_image.alt_text.presence || "#{@product.title} atmosphere", class: "w-full h-[400px] object-cover rounded-lg" %>
      </div>
      <div class="order-1 md:order-2 space-y-6 md:pl-12">
        <h2 class="text-3xl font-headline font-bold italic"><%= @product.story_title_for_display %></h2>
        <p class="text-body-md text-on-surface-variant leading-relaxed">
          <%= @product.story_body_for_display %>
        </p>
        <div class="pt-4">
          <%= link_to "Request Historical Provenance", new_user_session_path, class: "text-primary font-bold tracking-widest uppercase text-xs border-b border-primary/30 pb-1 hover:border-primary transition-all" %>
        </div>
      </div>
    </section>
  <% end %>
</main>
