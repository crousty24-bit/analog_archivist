<% content_for :title, "#{site_title} | Shipping Ledger" %>

<main class="max-w-screen-xl mx-auto px-4 sm:px-6 md:px-8 py-10 sm:py-12 md:py-16 grid grid-cols-1 lg:grid-cols-12 gap-10 md:gap-16 relative" data-controller="shipping-ledger" data-shipping-ledger-subtotal-cents-value="<%= current_cart.subtotal_cents %>">
  <div class="absolute inset-0 paper-texture pointer-events-none"></div>

  <section class="lg:col-span-7 space-y-12 relative z-10">
    <div>
      <h1 class="font-headline text-4xl sm:text-5xl italic text-on-surface mb-4">Shipping Ledger</h1>
      <p class="font-label text-on-surface-variant tracking-widest uppercase text-xs">Manifest No. <%= @order.manifest_number.presence || "Pending" %></p>
    </div>

    <% if @order.errors.any? %>
      <div class="flash-message flash-message-alert">
        <%= @order.errors.full_messages.to_sentence %>
      </div>
    <% end %>

    <%= form_with model: @order, url: orders_path, id: "shipping-ledger-form", class: "contents" do |form| %>
      <div class="bg-surface-container-highest p-6 sm:p-8 md:p-10 shadow-sm relative overflow-hidden">
        <div class="absolute top-0 left-0 w-1 h-full bg-primary opacity-20"></div>
        <h2 class="font-headline text-2xl italic mb-8 border-b border-outline-variant/30 pb-4">Consignee Details</h2>
        <div class="grid grid-cols-1 md:grid-cols-2 gap-x-8 gap-y-8 sm:gap-y-10">
          <div class="flex flex-col gap-2">
            <%= form.label :full_name, class: "font-label text-xs uppercase tracking-widest text-on-surface-variant" %>
            <%= form.text_field :full_name, required: true, placeholder: "E.g. Arthur C. Archivist", class: "bg-transparent border-t-0 border-x-0 border-b border-outline/40 focus:ring-0 focus:border-primary text-on-surface font-headline italic text-lg transition-all py-2 placeholder:opacity-100" %>
          </div>
          <div class="flex flex-col gap-2">
            <%= form.label :email, "Correspondence Email", class: "font-label text-xs uppercase tracking-widest text-on-surface-variant" %>
            <%= form.email_field :email, required: true, class: "bg-transparent border-t-0 border-x-0 border-b border-outline/40 focus:ring-0 focus:border-primary text-on-surface font-headline italic text-lg transition-all py-2 placeholder:opacity-100" %>
          </div>
          <div class="md:col-span-2 flex flex-col gap-2">
            <%= form.label :street_address, "Street Address", class: "font-label text-xs uppercase tracking-widest text-on-surface-variant" %>
            <%= form.text_field :street_address, required: true, placeholder: "123 Oakwood Manor, The Old Library District", class: "bg-transparent border-t-0 border-x-0 border-b border-outline/40 focus:ring-0 focus:border-primary text-on-surface font-headline italic text-lg transition-all py-2 placeholder:opacity-100" %>
          </div>
          <div class="flex flex-col gap-2">
            <%= form.label :city_province, "City / Province", class: "font-label text-xs uppercase tracking-widest text-on-surface-variant" %>
            <%= form.text_field :city_province, required: true, placeholder: "San Francisco", class: "bg-transparent border-t-0 border-x-0 border-b border-outline/40 focus:ring-0 focus:border-primary text-on-surface font-headline italic text-lg transition-all py-2 placeholder:opacity-100" %>
          </div>
          <div class="flex flex-col gap-2">
            <%= form.label :postal_code, "Postal Code", class: "font-label text-xs uppercase tracking-widest text-on-surface-variant" %>
            <%= form.text_field :postal_code, required: true, placeholder: "94103", class: "bg-transparent border-t-0 border-x-0 border-b border-outline/40 focus:ring-0 focus:border-primary text-on-surface font-headline italic text-lg transition-all py-2 placeholder:opacity-100" %>
          </div>
          <div class="md:col-span-2 mt-4">
            <label class="flex items-center gap-3 cursor-pointer group">
              <%= form.check_box :billing_matches_shipping, class: "w-4 h-4 rounded-sm border-outline/40 text-primary focus:ring-primary/20" %>
              <span class="font-body text-sm text-on-surface-variant group-hover:text-on-surface transition-colors">Billing address matches shipping manifest</span>
            </label>
          </div>
        </div>
      </div>

      <div class="bg-surface-container-low p-6 sm:p-8 md:p-10 shadow-sm relative overflow-hidden">
        <h2 class="font-headline text-2xl italic mb-8 border-b border-outline-variant/30 pb-4">Dispatch Method</h2>
        <div class="space-y-4">
          <% Order.shipping_options.each do |identifier, option| %>
            <label class="flex flex-col items-start gap-4 p-4 border border-outline-variant/20 hover:border-primary/40 cursor-pointer transition-all bg-surface-container-lowest sm:flex-row sm:items-center sm:justify-between">
              <div class="flex items-center gap-4">
                <%= form.radio_button :shipping_method, identifier, checked: @order.shipping_method == identifier, data: { action: "change->shipping-ledger#updateTotals", amount_cents: option[:amount_cents] }, class: "w-4 h-4 text-primary focus:ring-primary/20" %>
                <div>
                  <p class="font-headline italic text-lg"><%= option[:label] %></p>
                  <p class="font-body text-xs text-on-surface-variant"><%= option[:description] %></p>
                </div>
              </div>
              <span class="font-headline italic text-xl self-end sm:self-auto"><%= archive_price(option[:amount_cents], strip_zero_cents: false) %></span>
            </label>
          <% end %>
        </div>
      </div>
    <% end %>
  </section>

  <aside class="lg:col-span-5 space-y-8 relative z-10">
    <%= render "shared/cart_summary", order: @order %>
  </aside>
</main>
